; wrangler 4.109.0 bumped its peer to @cloudflare/workers-types@^5, which
; conflicts with @cloudflare/next-on-pages (pins ^4) during the Cloudflare Pages
; build (`npx @cloudflare/next-on-pages`). The types are build-time only and do
; not affect the generated output, so allow the peer mismatch instead of failing.
legacy-peer-deps=true
